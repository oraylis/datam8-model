{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://oraylis.de/datam8/functions/Transformation.json",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "stepNo",
    "kind",
    "name"
  ],
  "properties": {
    "stepNo": {
      "type": "integer"
    },
    "kind": {
      "enum": [
        "custom",
        "builtin",
        "function"
      ]
    },
    "name": {
      "type": "string"
    },
    "function": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source"
      ],
      "properties": {
        "source": {
          "type": "string"
        }
      }
    }
  },
  "if": {
    "properties": {
      "kind": {
        "const": "function"
      }
    }
  },
  "then": {
    "required": [
      "stepNo",
      "kind",
      "name",
      "function"
    ]
  },
  "else": {
    "required": [
      "stepNo",
      "kind",
      "name"
    ]
  }
}
