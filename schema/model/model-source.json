{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://oraylis.de/datam8/schema/model/model-source.json",
  "title": "ModelSource",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "sourceLocation"
  ],
  "properties": {
    "properties": {
      "type": "array",
      "items": {
        "$ref": "../property.json#/definitions/PropertyReference"
      }
    },
    "dataSource": {
      "description": "If not set or set to null then the source location will be assumed to point to an internal object",
      "type": "string"
    },
    "sourceLocation": {
      "description": "Points either to an internal DataEntity ID or a source object",
      "$comment": "TODO: clarify if we will use ids internally",
      "type": [
        "string",
        "number"
      ]
    },
    "mapping": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/SourceAttributeMapping"
      }
    }
  },
  "if": {
    "anyOf": [
      {
        "properties": {
          "dataSource": {
            "type": "null"
          }
        }
      },
      {
        "properties": {
          "dataSource": false
        }
      }
    ]
  },
  "then": {
    "$ref": "#/definitions/InternalDataSource"
  },
  "else": {
    "$ref": "#/definitions/ExternalDataSource"
  },
  "definitions": {
    "ExternalDataSource": {
      "required": [
        "dataSource",
        "sourceLocation"
      ],
      "properties": {
        "sourceLocation": {
          "type": "string"
        },
        "dataSource": true
      }
    },
    "InternalDataSource": {
      "required": [
        "sourceLocation"
      ],
      "properties": {
        "sourceLocation": true
      }
    },
    "SourceAttributeMapping": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "targetName",
        "sourceName"
      ],
      "properties": {
        "targetName": {
          "type": "string"
        },
        "sourceName": {
          "type": "string"
        },
        "sourceDataType": {
          "$ref": "../data-type.json"
        },
        "properties": {
          "type": "array",
          "items": {
            "$ref": "../property.json#/definitions/PropertyReference"
          }
        }
      }
    }
  }
}
