{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "$id": "https://oraylis.de/datam8/common/DataProduct.json",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "name": {
      "type": "string"
    },
    "displayName": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "tags": {
      "type": "array",
      "items": {
        "$ref": "./Tag.json"
      }
    },
    "parameters": {
      "type": "array",
      "items": {
        "$ref": "./Parameter.json"
      }
    },
    "module": {
      "type": "array",
      "items": {
        "$ref": "./DataModule.json"
      }
    }
  }
}
