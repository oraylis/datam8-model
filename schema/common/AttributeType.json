{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://oraylis.de/datam8/common/AttributeType.json",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "name": {
      "type": "string"
    },
    "displayName": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "parameters": {
      "type": "array",
      "items": {
        "$ref": "./Parameter.json"
      }
    },
    "defaultType": {
      "type": "string"
    },
    "defaultLength": {
      "type": "integer"
    },
    "defaultPrecision": {
      "type": "integer"
    },
    "defaultScale": {
      "type": "integer"
    },
    "hasUnit": {
      "enum": [
        "NoUnit",
        "Physical",
        "Currency",
        "UnitFree"
      ],
      "type": "string"
    },
    "isUnit": {
      "enum": [
        "NoUnit",
        "Physical",
        "Currency"
      ],
      "type": "string"
    },
    "canBeInRelation": {
      "type": "boolean",
      "default": "False"
    },
    "isDefaultProperty": {
      "type": "boolean",
      "default": "False"
    }
  },
  "required": [
    "name",
    "displayName",
    "defaultType"
  ]
}
