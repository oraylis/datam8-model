{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://oraylis.de/datam8/schema/data-source.json",
  "title": "DataSource",
  "description": "Defines an external source of data to be loaded with datam8.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "name",
    "type",
    "extendedProperties"
  ],
  "properties": {
    "name": {
      "type": "string"
    },
    "displayName": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "properties": {
      "type": "array",
      "items": {
        "$ref": "./property.json#/definitions/PropertyReference"
      }
    },
    "type": {
      "type": "string"
    },
    "dataTypeMapping": {
      "type": "array",
      "description": "Optional data type mappings. If not specified, uses defaults from DataSourceTypes. Individual mappings override defaults.",
      "items": {
        "$ref": "#/definitions/SourceDataTypeMapping"
      }
    },
    "extendedProperties": {
      "type": "object",
      "description": "Additional properties specific to the data source",
      "minProperties": 1,
      "additionalProperties": {
        "type": [
          "string",
          "boolean",
          "integer",
          "number"
        ]
      }
    }
  },
  "definitions": {
    "SourceDataTypeMapping": {
      "description": "A mapping of datatypes name in the source to datam8 internal datatype names.",
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "sourceType": {
          "type": "string",
          "description": "Source system data type"
        },
        "targetType": {
          "type": "string",
          "description": "Target system data type"
        }
      },
      "required": [
        "sourceType",
        "targetType"
      ]
    },
    "ConnectionProperty": {
      "description": "A property or setting defined by a data source type, which is then available when defining concret data sources.",
      "type": "object",
      "properties": {
        "name": {
          "type": "string"
        },
        "displayName": {
          "type": "string"
        },
        "required": {
          "type": "boolean",
          "default": false
        },
        "description": {
          "type": "string"
        },
        "type": {
          "title": "ConnectionPropertyValueType",
          "enum": [
            "string",
            "number",
            "boolean",
            "secret"
          ]
        },
        "default": {
          "type": [
            "string",
            "boolean",
            "integer",
            "number"
          ]
        }
      },
      "required": [
        "name",
        "required",
        "type"
      ]
    },
    "AuthMode": {
      "description": "A single authentiocation method",
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "required"
      ],
      "properties": {
        "name": {
          "type": "string"
        },
        "displayName": {
          "type": "string"
        },
        "required": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        },
        "optional": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "DataSourceType": {
      "description": "Defines groups of data sources that base on their technology, e.g. `SqlServer` or `Oracle`",
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "dataTypeMapping",
        "connectionProperties",
        "authModes"
      ],
      "properties": {
        "name": {
          "type": "string",
          "description": "Name of the data source type (e.g., SqlDataSource, LakeSource)"
        },
        "displayName": {
          "type": "string",
          "description": "Human-readable display name"
        },
        "description": {
          "type": "string",
          "description": "Description of the data source type"
        },
        "dataTypeMapping": {
          "type": "array",
          "description": "Default data type mappings for this source type",
          "minItems": 1,
          "items": {
            "$ref": "#/definitions/SourceDataTypeMapping"
          }
        },
        "pluginId": {
          "type": "string",
          "description": "ID of the plugin used to connect to the source type. If not provided falls back to builtin plugins matching the  name"
        },
        "connectionProperties": {
          "description": "Required connection properties for this source type",
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/definitions/ConnectionProperty"
          }
        },
        "authModes": {
          "description": "Describes different authentication modes and which connection properties are relevant for it.",
          "type": "array",
          "items": {
            "$ref": "#/definitions/AuthMode"
          }
        }
      }
    },
    "SourceObject": {
      "required": [
        "name",
        "type"
      ],
      "properties": {
        "schema": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "type": {
          "type": "string"
        }
      }
    },
    "SourceField": {
      "required": [
        "name",
        "ordinal",
        "dataType",
        "isNullable"
      ],
      "properties": {
        "name": {
          "type": "string"
        },
        "ordinal": {
          "type": "integer",
          "minimum": 1
        },
        "dataType": {
          "type": "string"
        },
        "maxLength": {
          "type": "integer",
          "minimum": 1
        },
        "numericPrecision": {
          "type": "integer",
          "minimum": 1
        },
        "numbericScale": {
          "type": "integer",
          "minimum": 1
        },
        "isNullable": {
          "type": "boolean"
        },
        "isPrimaryKey": {
          "type": "boolean"
        }
      }
    }
  }
}
