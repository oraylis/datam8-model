{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "$id": "https://oraylis.de/datam8/schema/folder.json",
  "title": "Folder",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "name"
  ],
  "properties": {
    "id": {
      "$ref": "./common.json#/definitions/Id"
    },
    "name": {
      "type": "string"
    },
    "displayName": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "path": {
      "description": "Path of this folder, if not set the current directory will be used.",
      "type": "string"
    },
    "properties": {
      "type": "array",
      "items": {
        "$ref": "./property.json#/definitions/PropertyReference"
      }
    }
  }
}
