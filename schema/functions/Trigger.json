{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://oraylis.de/datam8/functions/Trigger.json",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "mode": {
      "enum": [
        "schedule",
        "module",
        "event",
        "children"
      ]
    },
    "schedule": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "cronExpression": {
          "type": "string"
        },
        "timezone": {
          "type": "string"
        },
        "maxRetries": {
          "type": "integer"
        }
      }
    }
  }
}
