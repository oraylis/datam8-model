{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://oraylis.de/datam8/ModelDataEntity.json",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "type",
    "entity"
  ],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "type": {
      "const": "ModelDataEntity"
    },
    "entity": {
      "$ref": "./common/DataEntity.json"
    },
    "functions": {
      "type": "object",
      "required": [
        "trigger",
        "sources",
        "transformations",
        "store"
      ],
      "properties": {
        "trigger": {
          "$ref": "./functions/Trigger.json"
        },
        "sources": {
          "type": "array",
          "items": {
            "$ref": "./functions/Source.json"
          }
        },
        "transformations": {
          "type": "array",
          "items": {
            "$ref": "./functions/Transformation.json"
          }
        },
        "store": {
          "$ref": "./functions/Store.json"
        }
      }
    }
  }
}
