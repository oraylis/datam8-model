{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://oraylis.de/datam8/schema/attribute.json",
  "title": "Attribute",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "ordinalNumber",
    "name",
    "dataType",
    "attributeType"
  ],
  "properties": {
    "ordinalNumber": {
      "type": "integer"
    },
    "name": {
      "type": "string"
    },
    "displayName": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "attributeType": {
      "type": "string"
    },
    "dataType": {
      "$ref": "./data-type.json"
    },
    "type": {
      "enum": [
        "SCD0",
        "SCD1",
        "SCD2",
        "BK",
        "SK"
      ],
      "default": "SCD1"
    },
    "refactorNames": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "dateModified": {
      "type": "string"
    },
    "dateDeleted": {
      "type": "string"
    },
    "dateAdded": {
      "type": "string"
    },
    "properties": {
      "type": "array",
      "items": {
        "$ref": "./property.json#/definitions/PropertyReference"
      }
    }
  },
  "definitions": {
    "AttributeType": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string"
        },
        "displayName": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "defaultType": {
          "type": "string"
        },
        "defaultLength": {
          "type": "integer"
        },
        "defaultPrecision": {
          "type": "integer"
        },
        "defaultScale": {
          "type": "integer"
        },
        "hasUnit": {
          "enum": [
            "NoUnit",
            "Physical",
            "Currency",
            "UnitFree"
          ]
        },
        "isUnit": {
          "enum": [
            "NoUnit",
            "Physical",
            "Currency"
          ]
        },
        "canBeInRelation": {
          "type": "boolean",
          "default": false
        },
        "isDefaultProperty": {
          "type": "boolean",
          "default": false
        }
      },
      "required": [
        "name",
        "displayName",
        "defaultType"
      ]
    }
  }
}
