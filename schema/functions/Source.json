{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://oraylis.de/datam8/functions/Source.json",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "type": {
      "enum": [
        "model",
        "system"
      ]
    },
    "filter": {
      "type": "string"
    },
    "model": {
      "$ref": "#/definitions/model"
    },
    "source": {
      "$ref": "#/definitions/source"
    }
  },
  "if": {
    "properties": {
      "type": {
        "const": "model"
      }
    }
  },
  "then": {
    "required": [
      "type",
      "model"
    ]
  },
  "else": {
    "required": [
      "type",
      "source"
    ]
  },
  "definitions": {
    "model": {
      "type": "object",
      "required": [
        "dm8l"
      ],
      "properties": {
        "dm8l": {
          "type": "string"
        },
        "mapping": {
          "type": "array",
          "items": {
            "$ref": "../common/AttributeMapping.json"
          }
        }
      }
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "dataSource",
        "sourceLocation"
      ],
      "properties": {
        "dataSource": {
          "type": "string"
        },
        "sourceLocation": {
          "type": "string"
        },
        "filter": {
          "type": "string"
        },
        "extract": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "type": {
              "enum": [
                "full",
                "delta"
              ]
            },
            "full": {
              "type": "object",
              "additionalProperties": false
            },
            "delta": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "column": {
                  "type": "string"
                }
              }
            }
          }
        },
        "mapping": {
          "type": "array",
          "items": {
            "$ref": "../common/AttributeMapping.json"
          }
        }
      }
    }
  }
}
