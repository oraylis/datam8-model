{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://oraylis.de/datam8/schema/model/model.json",
  "title": "ModelEntity",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "name",
    "type",
    "displayName",
    "attributes",
    "sources"
  ],
  "properties": {
    "id": {
      "type": "number"
    },
    "name": {
      "type": "string"
    },
    "type": {
      "const": "entity"
    },
    "displayName": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "parameters": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/ModelParameter"
      }
    },
    "attributes": {
      "type": "array",
      "items": {
        "$ref": "../attribute.json"
      }
    },
    "properties": {
      "type": "array",
      "items": {
        "$ref": "../property.json#/definitions/PropertyReference"
      }
    },
    "sources": {
      "type": "array",
      "items": {
        "$ref": "./model-source.json"
      }
    },
    "transformations": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/ModelTransformation"
      }
    }
  },
  "definitions": {
    "ModelParameter": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "value"
      ],
      "properties": {
        "name": {
          "type": "string"
        },
        "value": {
          "oneOf": [
            {
              "type": "string"
            },
            {
              "type": "object"
            },
            {
              "type": "number"
            },
            {
              "type": "boolean"
            }
          ]
        }
      }
    },
    "ModelTransformation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "stepNo",
        "name",
        "kind"
      ],
      "properties": {
        "stepNo": {
          "type": "integer"
        },
        "kind": {
          "enum": [
            "builtin",
            "function"
          ]
        },
        "name": {
          "type": "string"
        },
        "function": true
      },
      "if": {
        "properties": {
          "kind": {
            "const": "function"
          }
        }
      },
      "then": {
        "required": [
          "function"
        ],
        "properties": {
          "function": {
            "type": "object",
            "properties": {
              "source": {
                "type": "string"
              }
            }
          }
        }
      },
      "else": {
        "properties": {
          "function": false
        }
      }
    }
  }
}
