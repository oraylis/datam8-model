{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://oraylis.de/datam8/common/DataTypeObject.json",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "type",
    "nullable"
  ],
  "properties": {
    "type": {
      "type": "string"
    },
    "nullable": {
      "type": "boolean"
    },
    "charLen": {
      "type": "integer"
    },
    "precision": {
      "type": "integer"
    },
    "scale": {
      "type": "integer"
    }
  }
}
