{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "$id": "https://oraylis.de/datam8/schema/folder.json",
  "title": "Folder",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "type"
  ],
  "properties": {
    "id": {
      "type": "number"
    },
    "type": {
      "const": "folder"
    },
    "displayName": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "properties": {
      "type": "array",
      "items": {
        "$ref": "./property.json#/definitions/PropertyReference"
      }
    }
  }
}
