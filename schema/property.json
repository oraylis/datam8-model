{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://oraylis.de/datam8/schema/property.json",
  "title": "Property",
  "description": "Defines properties for which specific pre-selectable values can created.",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "name",
    "displayName"
  ],
  "properties": {
    "name": {
      "type": "string"
    },
    "displayName": {
      "type": "string"
    },
    "schema": {
      "type": "string"
    },
    "scopes": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "$ref": "#/definitions/PropertyScope"
      },
      "default": []
    }
  },
  "definitions": {
    "PropertyReference": {
      "description": "Used to reference from any entity to a `Property`.",
      "type": "object",
      "additionalProperties": false,
      "required": [
        "property",
        "value"
      ],
      "properties": {
        "property": {
          "type": "string"
        },
        "value": {
          "type": "string"
        }
      }
    },
    "PropertyScope": {
      "description": "Defines for which type of entities a `PropertyType` is available for assignment.",
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type"
      ],
      "properties": {
        "type": {
          "type": "string"
        },
        "singleUsage": {
          "description": "Defines if the `PropertyType` can only be assigned once to entities in this scope.",
          "type": "boolean",
          "default": true
        },
        "mandatory": {
          "type": "boolean",
          "default": false
        }
      }
    },
    "PropertyValue": {
      "description": "A single globally available static property value that can be referenced from other entities.",
      "type": "object",
      "additionalProperties": true,
      "required": [
        "name"
      ],
      "properties": {
        "name": {
          "type": "string"
        },
        "displayName": {
          "type": "string"
        },
        "default": {
          "type": "boolean",
          "default": false
        },
        "property": {
          "description": "The name of the associated property.",
          "type": "string"
        },
        "properties": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "$ref": "#/definitions/PropertyReference"
          }
        }
      }
    }
  }
}
