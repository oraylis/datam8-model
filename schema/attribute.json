{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://oraylis.de/datam8/schema/attribute.json",
  "title": "Attribute",
  "description": "An attribute of a model entity.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "ordinalNumber",
    "name",
    "dataType",
    "attributeType",
    "dateAdded"
  ],
  "properties": {
    "ordinalNumber": {
      "type": "integer",
      "exclusiveMinimum": 0
    },
    "name": {
      "type": "string"
    },
    "displayName": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "attributeType": {
      "type": "string"
    },
    "dataType": {
      "$ref": "./data-type.json"
    },
    "isBusinessKey": {
      "type": "boolean",
      "default": false
    },
    "history": {
      "title": "HistoryType",
      "description": "Defines how an attribute in a slowly chaning dimension should behave.",
      "enum": [
        "SCD0",
        "SCD1",
        "SCD2",
        "SCD3",
        "SCD4"
      ],
      "default": "SCD1"
    },
    "unit": {
      "$comment": "TODO: Validate conecpt of units and where they are maintaned.",
      "type": "string"
    },
    "refactorNames": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "dateModified": {
      "type": "string",
      "format": "date-time"
    },
    "dateDeleted": {
      "type": "string",
      "format": "date-time"
    },
    "dateAdded": {
      "type": "string",
      "format": "date-time"
    },
    "properties": {
      "type": "array",
      "items": {
        "$ref": "./property.json#/definitions/PropertyReference"
      }
    }
  },
  "definitions": {
    "AttributeType": {
      "description": "Defines abstract business orientated attribute definitions, e.g. an email address",
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "displayName",
        "defaultType"
      ],
      "properties": {
        "name": {
          "type": "string"
        },
        "displayName": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "defaultType": {
          "type": "string"
        },
        "defaultLength": {
          "type": "integer",
          "exclusiveMinimum": 0
        },
        "defaultPrecision": {
          "type": "integer",
          "exclusiveMinimum": 0
        },
        "defaultScale": {
          "type": "integer",
          "exclusiveMinimum": 0
        },
        "hasUnit": {
          "description": "Defines if an attribute should define a unit, e.g. `Physical` for weight or `Currency` for price.",
          "enum": [
            "NoUnit",
            "Physical",
            "Currency"
          ],
          "default": "NoUnit"
        },
        "canBeInRelation": {
          "type": "boolean",
          "default": false
        },
        "isDefaultProperty": {
          "type": "boolean",
          "default": false
        }
      }
    }
  }
}
