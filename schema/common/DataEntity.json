{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://oraylis.de/datam8/common/DataEntity.json",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "name",
    "displayName"
  ],
  "properties": {
    "name": {
      "type": "string"
    },
    "extensionOf": {
      "type": "string"
    },
    "displayName": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "parameters": {
      "type": "array",
      "items": {
        "$ref": "./Parameter.json"
      }
    },
    "tags": {
      "type": "array",
      "items": {
        "$ref": "./Tag.json"
      }
    },
    "attribute": {
      "type": "array",
      "items": {
        "$ref": "./Attribute.json"
      }
    }
  }
}
