{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://oraylis.de/datam8/schema/property.json",
  "title": "Property",
  "description": "A single globally available static attribute that can be referenced from other entities.",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "name",
    "type"
  ],
  "properties": {
    "name": {
      "type": "string"
    },
    "displayName": {
      "type": "string"
    },
    "default": {
      "type": "boolean",
      "default": false
    },
    "type": {
      "type": "string"
    },
    "properties": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/PropertyReference"
      }
    }
  },
  "definitions": {
    "PropertyReference": {
      "description": "Used to reference from any entity to a `Property`.",
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "value"
      ],
      "properties": {
        "type": {
          "type": "string"
        },
        "value": {
          "type": "string"
        }
      }
    },
    "PropertyScope": {
      "description": "Defines for which type of entities a `PropertyType` is available for assignment.",
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type"
      ],
      "properties": {
        "type": {
          "type": "string"
        },
        "singleUsage": {
          "description": "Defines if the `PropertyType` can only be assigned once to entities in this scope.",
          "type": "boolean",
          "default": true
        },
        "mandatory": {
          "type": "boolean",
          "default": false
        }
      }
    },
    "PropertyType": {
      "$comment": "TODO: this should be the Property, and Property should be e.g. PropertyValue?",
      "description": "Defines a group of Properties that are grouped together for selection purposes.",
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name"
      ],
      "properties": {
        "name": {
          "type": "string"
        },
        "displayName": {
          "type": "string"
        },
        "schema": {
          "type": "string"
        },
        "scopes": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/PropertyScope"
          },
          "default": []
        }
      }
    }
  }
}
