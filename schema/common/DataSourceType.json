{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://oraylis.de/datam8/common/DataSourceType.json",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "name": {
      "type": "string",
      "description": "Name of the data source type (e.g., SqlDataSource, LakeSource)"
    },
    "displayName": {
      "type": "string",
      "description": "Human-readable display name"
    },
    "description": {
      "type": "string",
      "description": "Description of the data source type"
    },
    "dataTypeMapping": {
      "type": "array",
      "description": "Default data type mappings for this source type",
      "items": {
        "$ref": "./DataTypeMapping.json"
      }
    },
    "connectionProperties": {
      "type": "array",
      "description": "Required connection properties for this source type",
      "items": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "required": {
            "type": "boolean"
          },
          "description": {
            "type": "string"
          }
        },
        "required": [
          "name",
          "required"
        ]
      }
    }
  },
  "required": [
    "name",
    "displayName",
    "description"
  ]
}
