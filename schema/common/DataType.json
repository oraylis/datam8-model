{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://oraylis.de/datam8/common/DataType.json",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "name",
    "parquetType",
    "sqlType"
  ],
  "properties": {
    "name": {
      "type": "string"
    },
    "displayName": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "tags": {
      "type": "array",
      "items": {
        "$ref": "./Tag.json"
      }
    },
    "parameters": {
      "type": "array",
      "items": {
        "$ref": "./Parameter.json"
      }
    },
    "hasCharLen": {
      "type": "boolean",
      "default": "False"
    },
    "hasPrecision": {
      "type": "boolean",
      "default": "False"
    },
    "hasScale": {
      "type": "boolean",
      "default": "False"
    },
    "parquetType": {
      "type": "string"
    },
    "sqlType": {
      "type": "string"
    }
  }
}
